<Window x:Class="TaskTool.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="176" Height="32"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="Manual"
        SnapsToDevicePixels="True"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp"
        MouseMove="Window_MouseMove">
    <Border x:Name="IslandRoot"
            CornerRadius="18"
            Background="#EA0A0F17"
            BorderBrush="#3A4455"
            BorderThickness="1"
            Padding="14,10"
            IsHitTestVisible="True"
            ClipToBounds="False"
            MouseLeftButtonUp="IslandRoot_MouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.28" Color="#000000"/>
        </Border.Effect>

        <Grid x:Name="ContentHost" VerticalAlignment="Top" HorizontalAlignment="Stretch" MinHeight="0" IsHitTestVisible="True">

            <Border x:Name="NotificationOverlay"
                    Margin="0"
                    MinHeight="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    CornerRadius="12"
                    Padding="15"
                    Panel.ZIndex="4"
                    IsHitTestVisible="True"
                    Background="#F0111724"
                    BorderThickness="1"
                    Visibility="{Binding HasNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#F59E0B"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStartNotification}" Value="True">
                                <Setter Property="BorderBrush" Value="#EF4444"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid VerticalAlignment="Top" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="28"
                            Height="28"
                            CornerRadius="14"
                            VerticalAlignment="Center"
                            Background="#203B4454">
                        <TextBlock Text="🔔"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#E5E7EB"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                        <TextBlock Text="Benachrichtigung" Foreground="#BFC9D8" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{Binding NotificationText}" TextWrapping="Wrap" Foreground="#E6EAF2" Margin="0,2,0,0" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Top">
                        <Button x:Name="NotificationOpenButton" Content="🔗 Öffnen" Click="NotificationOpenButton_Click"
                                Style="{StaticResource IslandPillButtonStyle}" Margin="0,0,0,8" MinHeight="30" MinWidth="110"/>
                        <Button x:Name="NotificationCloseButton" Content="✖ Schließen" Click="NotificationCloseButton_Click"
                                Style="{StaticResource IslandPillButtonStyle}" MinHeight="30" MinWidth="110"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel x:Name="ExpandedContentHost" Margin="0" Panel.ZIndex="2" MinHeight="120" Opacity="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                    <Condition Binding="{Binding HasNotification}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,6">
                    <TextBlock Text="🎯" FontFamily="Segoe UI Emoji" FontSize="14" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TaskTitle}" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                </StackPanel>

                <TextBlock Text="{Binding TimerDisplay}" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,0,0,8"/>

                <Button Command="{Binding OpenNextFocusCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="0,0,0,8"
                        Visibility="{Binding ShowNextFocus, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Content>
                        <TextBlock Text="{Binding NextFocusText}" Foreground="#CBD5E1" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Button.Content>
                </Button>

                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <Button Content="▶️ Start / ⏸ Stop" Command="{Binding StartStopCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="🔗 Öffnen" Command="{Binding OpenTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,6">
                    <Button Content="➕ Neue Aufgabe" Command="{Binding NewTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="🔗 Link öffnen" Command="{Binding OpenLinkCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"
                            Visibility="{Binding HasTicketUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
