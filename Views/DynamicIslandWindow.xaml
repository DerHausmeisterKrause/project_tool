<Window x:Class="TaskTool.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="168" Height="24"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    <Border x:Name="IslandRoot"
            CornerRadius="14"
            Background="#CC0B1220"
            BorderBrush="#2A3345"
            BorderThickness="1"
            Padding="6,4"
            MouseLeftButtonUp="IslandRoot_MouseLeftButtonUp">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#2A3345"/>
                <Setter Property="Background" Value="#CC0B1220"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                        <Setter Property="Background" Value="#EA0C1320"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Closed state: no text/content, minimal pill only -->
            <Grid Grid.Row="0" Height="16" Visibility="{Binding IsExpanded, Converter={StaticResource InverseBooleanConverter}}"/>

            <StackPanel Grid.Row="1" Margin="0,4,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <TextBlock Text="🔔" FontFamily="Segoe UI Emoji" FontSize="14" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TaskTitle}" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                </StackPanel>

                <TextBlock Text="{Binding TimerDisplay}" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,0,0,8"/>

                <TextBlock Text="{Binding NextFocusText}" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,0,0,8"
                           Visibility="{Binding ShowNextFocus, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <Button Content="Start / Stop" Command="{Binding StartStopCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="Aufgabe öffnen" Command="{Binding OpenTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,6">
                    <Button Content="Neue Aufgabe" Command="{Binding NewTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="Link öffnen" Command="{Binding OpenLinkCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"
                            Visibility="{Binding HasTicketUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
