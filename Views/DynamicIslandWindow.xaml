<Window x:Class="TaskTool.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="56"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    <Border x:Name="IslandRoot"
            CornerRadius="28"
            Background="#EA0C1320"
            BorderBrush="#334155"
            BorderThickness="1"
            Padding="10"
            MouseLeftButtonUp="IslandRoot_MouseLeftButtonUp">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#334155"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7ED;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding TaskTitle}" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13"
                               Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                               TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                </StackPanel>

                <Border Grid.Column="1" Width="14" Height="14" CornerRadius="7" Background="#1E293B" BorderBrush="#334155" BorderThickness="1"
                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1E293B"/>
                            <Style.Triggers>
                                <Trigger Property="IsVisible" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,10,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding TimerDisplay}" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,0,0,8"/>

                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <Button Content="Start / Stop" Command="{Binding StartStopCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="Aufgabe öffnen" Command="{Binding OpenTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,0,0,6">
                    <Button Content="+15" Command="{Binding Add15Command}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="+30" Command="{Binding Add30Command}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="+1h" Command="{Binding Add60Command}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,0,0,6">
                    <Button Content="-15" Command="{Binding Subtract15Command}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="-30" Command="{Binding Subtract30Command}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="-1h" Command="{Binding Subtract60Command}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                </UniformGrid>

                <Button Content="Link öffnen" Command="{Binding OpenLinkCommand}" Style="{StaticResource IslandPillButtonStyle}"
                        Visibility="{Binding HasTicketUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
