<Window x:Class="TaskTool.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="176" Height="32"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        SnapsToDevicePixels="True"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp"
        MouseMove="Window_MouseMove">
    <Border x:Name="IslandRoot"
            CornerRadius="18"
            Background="#EA0A0F17"
            BorderBrush="#3A4455"
            BorderThickness="1"
            Padding="10,7"
            ClipToBounds="True"
            MouseLeftButtonUp="IslandRoot_MouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.32" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="18"/>

            <!-- Eigenständiger NotificationOverlay Modus -->
            <Border Grid.Row="1"
                    x:Name="NotificationOverlay"
                    Margin="0,8,0,0"
                    CornerRadius="12"
                    Padding="10,8"
                    Panel.ZIndex="4"
                    Background="#E6121721"
                    BorderThickness="2"
                    Visibility="{Binding HasNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#F59E0B"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStartNotification}" Value="True">
                                <Setter Property="BorderBrush" Value="#EF4444"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="🔔"
                               FontFamily="Segoe UI Emoji"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Foreground="#E5E7EB"
                               Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Benachrichtigung" Foreground="#E5E7EB" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding NotificationText}" TextWrapping="Wrap" Foreground="#F8FAFC" Margin="0,4,0,8"/>
                        <UniformGrid Columns="2">
                            <Button Content="🔗 Öffnen" Command="{Binding OpenNotificationCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="2"/>
                            <Button Content="✖ Schließen" Command="{Binding DismissNotificationCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="2"/>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Normaler Expanded Modus (getrennt vom NotificationOverlay) -->
            <StackPanel Grid.Row="1" Margin="0,8,0,0" Panel.ZIndex="2">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                    <Condition Binding="{Binding HasNotification}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <TextBlock Text="🎯" FontFamily="Segoe UI Emoji" FontSize="14" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TaskTitle}" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                </StackPanel>

                <TextBlock Text="{Binding TimerDisplay}" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,0,0,8"/>

                <Button Command="{Binding OpenNextFocusCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="0,0,0,8"
                        Visibility="{Binding ShowNextFocus, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Content>
                        <TextBlock Text="{Binding NextFocusText}" Foreground="#CBD5E1" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Button.Content>
                </Button>

                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <Button Content="▶️ Start / ⏸ Stop" Command="{Binding StartStopCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="🔗 Öffnen" Command="{Binding OpenTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,6">
                    <Button Content="➕ Neue Aufgabe" Command="{Binding NewTaskCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"/>
                    <Button Content="🔗 Link öffnen" Command="{Binding OpenLinkCommand}" Style="{StaticResource IslandPillButtonStyle}" Margin="4,0"
                            Visibility="{Binding HasTicketUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
