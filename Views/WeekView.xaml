<UserControl x:Class="TaskTool.Views.WeekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <Style x:Key="WeekNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="#334155"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Command}" Value="{x:Null}">
                    <Setter Property="Background" Value="#334155"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <DockPanel LastChildFill="False">
                <Button Content="← Vorherige Woche" Width="150" Style="{StaticResource WeekNavButtonStyle}" Command="{Binding PreviousWeekCommand}"/>
                <Button Content="Diese Woche" Width="120" Style="{StaticResource WeekNavButtonStyle}" Command="{Binding CurrentWeekCommand}"/>
                <Button Content="Nächste Woche →" Width="150" Style="{StaticResource WeekNavButtonStyle}" Command="{Binding NextWeekCommand}"/>
                <TextBlock Text="{Binding WeekRangeLabel}" FontSize="22" FontWeight="SemiBold" Margin="14,4,0,0"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="Transparent" CanContentScroll="False">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding TimeColumnWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,1,1" Height="58"/>

                    <ItemsControl x:Name="SelectedDayOverlayColumns" Grid.RowSpan="2" Grid.Column="1" ItemsSource="{Binding Days}" IsHitTestVisible="False" Panel.ZIndex="25">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding DataContext.DayColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Height="{Binding DataContext.FullDayColumnHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource BorderBrushColor}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Setter Property="Background" Value="#1A2560"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding DataContext.DayColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushColor}"
                                        BorderThickness="1,1,1,0"
                                        Padding="8,6" PreviewMouseDown="DayColumn_PreviewMouseDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}"/>
                                            <Setter Property="BorderThickness" Value="1,1,1,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Background" Value="#14243B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#172033"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2,2,2,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding DayLabel}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <Border Margin="6,0,0,0" Padding="6,1" CornerRadius="8" Background="#1D4ED8"
                                                    Visibility="{Binding IsToday, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Heute" FontSize="10" FontWeight="SemiBold" Foreground="#EAF2FF"/>
                                            </Border>
                                            <Border Margin="6,0,0,0" Padding="6,1" CornerRadius="8" Background="#2563EB"
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="SELECTED" FontSize="10" FontWeight="Bold" Foreground="#EAF2FF"/>
                                            </Border>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,2,0,2">
                                            <Border Style="{StaticResource BadgeStyle}"><TextBlock Text="{Binding DayType}"/></Border>
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsHo, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Text="HO"/></Border>
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsBr, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Text="BR"/></Border>
                                        </WrapPanel>
                                        <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                                        <ItemsControl ItemsSource="{Binding AllDayEvents}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1E3A8A" BorderBrush="#60A5FA" BorderThickness="1" CornerRadius="9" Padding="6,2" Margin="0,0,4,4">
                                                        <Border.ToolTip>
                                                            <ToolTip Background="{StaticResource SurfaceAltBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrushColor}" Padding="8">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Subject}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Location}" Visibility="{Binding Location, Converter={StaticResource StringEmptyToVisibilityConverter}}" Foreground="{StaticResource MutedTextBrush}"/>
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.OpenOutlookEventCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <TextBlock Text="{Binding Subject}" FontSize="10" TextTrimming="CharacterEllipsis" MaxWidth="170" Foreground="#DBEAFE"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,1,0">
                        <Grid Height="{Binding CalendarBodyHeight}">
                            <ItemsControl ItemsSource="{Binding TimeGridLines}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="1" Width="{Binding DataContext.TimeColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" Background="#243244" Opacity="0.6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding TimeAxisLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                        <Setter Property="Canvas.Left" Value="8"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <ItemsControl x:Name="DaySegmentColumns" Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding DataContext.DayColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Height="{Binding DataContext.CalendarBodyHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Background="#0F172A"
                                        BorderBrush="{StaticResource BorderBrushColor}"
                                        BorderThickness="1,0,1,1" PreviewMouseDown="DayColumn_PreviewMouseDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}"/>
                                            <Setter Property="BorderThickness" Value="1,0,1,1"/>
                                            <Setter Property="Background" Value="#0F172A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Background" Value="#0F1D30"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2,0,2,2"/>
                                                    <Setter Property="Background" Value="#122136"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid ClipToBounds="True">
                                        <ItemsControl ItemsSource="{Binding DataContext.TimeGridLines, RelativeSource={RelativeSource AncestorType=UserControl}}" IsHitTestVisible="False">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Height="1" Width="{Binding DataContext.DayColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" Background="#243244" Opacity="0.55"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding ExternalEvents}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding DisplayTop}"/>
                                                    <Setter Property="Canvas.Left" Value="{Binding DisplayLeft}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}" Background="#335B3A" BorderBrush="#5EEAD4" BorderThickness="1" CornerRadius="8" Padding="8,5" Opacity="0.82" ClipToBounds="True">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.OpenOutlookEventCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.ToolTip>
                                                            <ToolTip Background="{StaticResource SurfaceAltBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrushColor}" Padding="8">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding TooltipText}" TextWrapping="Wrap" MaxWidth="300"/>
                                                                    <Button Content="Teams öffnen" Width="120" Margin="0,6,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                                                            Visibility="{Binding HasTeamsLink, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                            Command="{Binding DataContext.OpenTeamsUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding TeamsJoinUrl}"/>
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <StackPanel>
                                                            <TextBlock Text="📅 Outlook" FontSize="10" Foreground="#CFFAFE"/>
                                                            <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                            <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="#D1FAE5"/>
                                                            <TextBlock Text="{Binding Location}" FontSize="10" Foreground="#BAE6FD" TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding ShowLocation, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            <Button Content="In Outlook öffnen" Width="120" Margin="0,4,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                                                    Visibility="{Binding ShowActions, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Command="{Binding DataContext.OpenOutlookEventCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button Content="Teams öffnen" Width="110" Margin="0,4,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                                                    Visibility="{Binding HasTeamsLink, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Command="{Binding DataContext.OpenTeamsUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding TeamsJoinUrl}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding CalendarItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding DisplayTop}"/>
                                                    <Setter Property="Canvas.Left" Value="{Binding DisplayLeft}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}" Background="#223347" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="9" Padding="8,6">
                                                        <Border.ToolTip>
                                                            <ToolTip Background="{StaticResource SurfaceAltBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrushColor}" Padding="8">
                                                                <TextBlock Text="{Binding TooltipText}" TextWrapping="Wrap" MaxWidth="320"/>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}"/>
                                                                <Setter Property="Background" Value="#223347"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                        <Setter Property="Background" Value="#29415A"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding HasOutlookConflict}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                                                        <Setter Property="Background" Value="#3C1F2A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.OpenCalendarItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Text="{Binding TaskTitle}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Row="1" Text="{Binding SegmentNote}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding ShowNote, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            <TextBlock Grid.Row="2" Text="{Binding TimeLabel}" Foreground="{StaticResource TextBrush}" FontSize="11"
                                                                       Visibility="{Binding ShowTime, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Canvas x:Name="NowIndicatorCanvas" Grid.Row="1" Grid.Column="1" Height="{Binding ElementName=DaySegmentColumns, Path=ActualHeight}" Width="{Binding ElementName=DaySegmentColumns, Path=ActualWidth}" IsHitTestVisible="False" ClipToBounds="True" Panel.ZIndex="20"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Visibility="{Binding ShowNowIndicator, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Rectangle x:Name="NowLine" Canvas.Left="0" Canvas.Top="{Binding NowLineTop}" Width="{Binding ElementName=DaySegmentColumns, Path=ActualWidth}" Height="2" Fill="White" Opacity="0.85"/>
                        <Ellipse Canvas.Left="{Binding NowMarkerLeft}" Canvas.Top="{Binding NowMarkerTop}" Width="8" Height="8" Fill="White" Opacity="0.95"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Markierungen für ausgewählten Tag:" Margin="0,0,0,8"/>
                <Border Background="Transparent" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="16" Padding="0" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="WeekDayType" Content="Normal" Style="{StaticResource DayMarkerSegmentLeftStyle}"
                                     IsChecked="{Binding SelectedDayType, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Normal}" Command="{Binding SetDayTypeNormalCommand}"/>
                        <RadioButton GroupName="WeekDayType" Content="UL" Style="{StaticResource DayMarkerSegmentMiddleStyle}"
                                     IsChecked="{Binding SelectedDayType, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=UL}" Command="{Binding SetDayTypeUlCommand}"/>
                        <RadioButton GroupName="WeekDayType" Content="AM" Style="{StaticResource DayMarkerSegmentRightStyle}"
                                     IsChecked="{Binding SelectedDayType, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=AM}" Command="{Binding SetDayTypeAmCommand}"/>
                    </StackPanel>
                </Border>
                <WrapPanel Margin="0,8,0,0">
                    <ToggleButton Content="HO" Style="{StaticResource DayMarkerChipToggleStyle}" IsChecked="{Binding SelectedIsHo, Mode=OneWay}" Command="{Binding ToggleHoCommand}"/>
                    <ToggleButton Content="BR" Style="{StaticResource DayMarkerChipToggleStyle}" IsChecked="{Binding SelectedIsBr, Mode=OneWay}" Command="{Binding ToggleBrCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
